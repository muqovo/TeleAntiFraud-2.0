# OpenAI-compatible LLM provider for API generation/evaluation.
# Use OPENAI_API_KEY by default, or set another env var and update configs/*.yaml.
OPENAI_API_KEY=

# Examples for other OpenAI-compatible providers:
# DASHSCOPE_API_KEY=
# SILICONFLOW_API_KEY=

# Higgs V3-compatible speech endpoint.
# Example: http://HOST:PORT/v1/audio/speech
HIGGS_TTS_API_URL=
